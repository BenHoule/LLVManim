[importlinter]
root_package = llvmanim
include_external_packages = True

[importlinter:contract:ingest_does_not_depend_on_render]
name = Ingest layer must not depend on render layer
type = forbidden
source_modules =
    llvmanim.ingest
forbidden_modules =
    llvmanim.render

[importlinter:contract:transform_does_not_depend_on_render]
name = Transform layer must not depend on render layer
type = forbidden
source_modules =
    llvmanim.transform
forbidden_modules =
    llvmanim.render

[importlinter:contract:core_does_not_depend_on_cli]
name = Core packages must not import CLI
type = forbidden
source_modules =
    llvmanim.ingest
    llvmanim.transform
    llvmanim.render
forbidden_modules =
    llvmanim.cli
