/**
 * 01b1_ir_parsing.dot
 *
 * Extracted subgraph: IR parsing path from 01b_ingest_layer.
 * Covers parse_module_to_events → ProgramEventStream,
 * the step that turns raw LLVM-IR bytes into structured event data.
 *
 * Render:
 *   dot -Tpdf 01b1_ir_parsing.dot -o ../01b1_ir_parsing.pdf
 */
digraph ir_parsing {
    graph [
        rankdir  = LR
        fontname = "Helvetica" fontsize = 10
        label    = "Ingest: IR Parsing Path"
        labelloc = t
        splines  = ortho
        nodesep  = 0.35
        ranksep  = 0.6
        pad      = 0.2
        bgcolor  = "white"
    ]
    node [fontname="Helvetica" fontsize=8 style=filled shape=box margin="0.08,0.04"]
    edge [fontname="Helvetica" fontsize=7 arrowhead=normal color="#555555"]

    /* ── External stub (incoming) ───────────────────────────────── */
    cli_main [label="cli/main.py\n← CLI" fillcolor="#f4b8d4" fontcolor="#7a1545"]

    /* ── Ingest cluster ─────────────────────────────────────────── */
    subgraph cluster_ingest {

        label     = "Ingest  (llvmanim/ingest/)"
        style     = filled
        fillcolor = "#d5f5e3"
        color     = "#1e8449"
        margin    = 8
        labeljust = l

        in_ll        [label=".ll file" fillcolor="#fef0bc" fontcolor="#9a6f00" shape=note]
        parse_events [label="parse_module_to_events()\nllvm_events.py"
                      fillcolor="#27ae60" fontcolor="white"]
        pes          [label="ProgramEventStream" fillcolor="#f5cba7" fontcolor="#ca6f1e" shape=note]

        in_ll -> parse_events
        parse_events -> pes
    }

    /* ── Third-party ────────────────────────────────────────────── */
    llvmlite [label="llvmlite\n(3rd party)" fillcolor="#bdc3c7" fontcolor="#2c3e50"]

    /* ── External stub (outgoing) ───────────────────────────────── */
    build_sg [label="build_scene_graph()\n→ Transform" fillcolor="#f5cba7" fontcolor="#ca6f1e"]

    /* ── Edges ──────────────────────────────────────────────────── */
    cli_main     -> in_ll    [minlen=1]
    pes          -> build_sg [minlen=1]
    parse_events -> llvmlite [style=dashed arrowhead=open xlabel="«import»" fontcolor="#2c3e50" color="#999999" constraint=false]
}
