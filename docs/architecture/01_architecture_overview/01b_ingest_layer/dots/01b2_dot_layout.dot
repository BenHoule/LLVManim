/**
 * 01b2_dot_layout.dot
 *
 * Extracted subgraph: DOT layout computation path from 01b_ingest_layer.
 * compute_dot_layout() invokes the graphviz Python package to assign
 * node positions, which CFGRenderer and graphviz_export then consume.
 *
 * Render:
 *   dot -Tpdf 01b2_dot_layout.dot -o ../01b2_dot_layout.pdf
 */
digraph dot_layout_path {
    graph [
        rankdir  = LR
        fontname = "Helvetica" fontsize = 10
        label    = "Ingest: DOT Layout Path"
        labelloc = t
        splines  = ortho
        nodesep  = 0.35
        ranksep  = 0.6
        pad      = 0.2
        bgcolor  = "white"
    ]
    node [fontname="Helvetica" fontsize=8 style=filled shape=box margin="0.08,0.04"]
    edge [fontname="Helvetica" fontsize=7 arrowhead=normal color="#555555"]

    /* ── External stub (incoming) ───────────────────────────────── */
    cli_main [label="cli/main.py\n← CLI" fillcolor="#f4b8d4" fontcolor="#7a1545"]

    /* ── Ingest cluster ─────────────────────────────────────────── */
    subgraph cluster_ingest {

        label     = "Ingest  (llvmanim/ingest/)"
        style     = filled
        fillcolor = "#d5f5e3"
        color     = "#1e8449"
        margin    = 8
        labeljust = l

        in_dot     [label=".dot file" fillcolor="#fef0bc" fontcolor="#9a6f00" shape=note]
        dot_layout [label="compute_dot_layout()\ndot_layout.py"
                    fillcolor="#27ae60" fontcolor="white"]

        in_dot -> dot_layout
    }

    /* ── Third-party ────────────────────────────────────────────── */
    graphviz [label="graphviz\n(3rd party)" fillcolor="#bdc3c7" fontcolor="#2c3e50"]

    /* ── Data output nodes ──────────────────────────────────────── */
    dot_layout_data [label="DotLayout" fillcolor="#a9cce3" fontcolor="#1a5276" shape=note]
    draw_flag       [label="--draw"    fillcolor="#a9cce3" fontcolor="#1a5276" shape=note]

    /* ── External stubs (outgoing) ──────────────────────────────── */
    cfg_renderer [label="CFGRenderer\n→ Render"     fillcolor="#a9cce3" fontcolor="#1a5276"]
    gviz_export  [label="graphviz_export\n→ Render" fillcolor="#a9cce3" fontcolor="#1a5276"]

    /* ── Edges ──────────────────────────────────────────────────── */
    cli_main   -> in_dot        [minlen=1]
    dot_layout -> dot_layout_data [minlen=1]
    dot_layout_data -> cfg_renderer [minlen=1]
    dot_layout -> draw_flag     [minlen=1]
    draw_flag  -> gviz_export   [minlen=1]
    dot_layout -> graphviz [style=dashed arrowhead=open xlabel="«import»" fontcolor="#2c3e50" color="#999999"]
}
