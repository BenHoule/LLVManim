// Extracted subgraph: Supplemental I/O path from 01b_ingest_layer
// These three loaders are all optional: they read pre-computed JSON files
// to override or augment the data that build_scene_graph() would otherwise
// compute itself (trace auto-derivation, analysis metadata, CFG edge list).
digraph supplemental_io {
    graph [
        fontname = "Helvetica" fontsize = 13
        label    = "Ingest: Supplemental I/O"
        labelloc = "t" splines = ortho nodesep = 0.9 ranksep = 1.2
        pad = 0.4 bgcolor = "white"
    ]
    node [fontname="Helvetica" fontsize=11 style="filled,rounded" shape=box]
    edge [fontname="Helvetica" fontsize=10 color="#555555" arrowsize=0.85]

    // ── Inputs ─────────────────────────────────────────────────────
    in_trace    [label="trace.json\n(--import-trace)"
                 fillcolor="#fef0bc" fontcolor="#9a6f00" shape=note]
    in_meta     [label="analysis_metadata.json\n(--import-analysis-metadata)"
                 fillcolor="#fef0bc" fontcolor="#9a6f00" shape=note]
    in_edges    [label="cfg_edges.json\n(--import-cfg-edges)"
                 fillcolor="#fef0bc" fontcolor="#9a6f00" shape=note]

    // ── Internal ───────────────────────────────────────────────────
    subgraph cluster_ingest {

        label     = "Ingest  (llvmanim/ingest/)"
        style     = filled
        fillcolor = "#d5f5e3"
        color     = "#1e8449"
        penwidth  = 1.5
        fontname  = "Helvetica"
        fontsize  = 12
        fontcolor = "#1e8449"

        trace_io    [label="load_trace()\ntrace_io.py"
                     fillcolor="#27ae60" fontcolor="white"]
        meta_io     [label="load_analysis_metadata()\nanalysis_metadata_io.py"
                     fillcolor="#27ae60" fontcolor="white"]
        cfg_edge_io [label="load_cfg_edges()\ncfg_edge_io.py"
                     fillcolor="#27ae60" fontcolor="white"]
    }

    // ── External stubs ─────────────────────────────────────────────
    cli_main    [label="cli/main.py\n← CLI"             fillcolor="#f4b8d4" fontcolor="#7a1545"]
    build_scene [label="build_scene_graph()\n→ Transform" fillcolor="#f5cba7" fontcolor="#ca6f1e"]

    // ── Edges ──────────────────────────────────────────────────────
    cli_main -> trace_io    [minlen=2 xlabel="  --import-trace" fontcolor="#1e8449"]
    cli_main -> meta_io     [minlen=2 xlabel="  --import-analysis-metadata" fontcolor="#1e8449"]
    cli_main -> cfg_edge_io [minlen=2 xlabel="  --import-cfg-edges" fontcolor="#1e8449"]

    in_trace -> trace_io
    in_meta  -> meta_io
    in_edges -> cfg_edge_io

    trace_io    -> build_scene [style=dashed minlen=2 xlabel="  TraceOverlay\n(or auto-derived)" fontcolor="#ca6f1e"]
    meta_io     -> build_scene [minlen=2 xlabel="  BlockMetadata" fontcolor="#ca6f1e"]
    cfg_edge_io -> build_scene [style=dashed minlen=2 xlabel="  cfg_edges\n(override)" fontcolor="#ca6f1e"]
}
