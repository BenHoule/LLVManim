/**
 * 01b3_supplemental_io.dot
 *
 * Extracted subgraph: Supplemental I/O path from 01b_ingest_layer.
 * These three loaders are all optional: they read pre-computed JSON files
 * to override or augment the data that build_scene_graph() would otherwise
 * compute itself (trace auto-derivation, analysis metadata, CFG edge list).
 *
 * Render:
 *   dot -Tpdf 01b3_supplemental_io.dot -o ../01b3_supplemental_io.pdf
 */
digraph supplemental_io {
    graph [
        fontname = "Helvetica" fontsize = 10
        label    = "Ingest: Supplemental I/O"
        labelloc = t
        splines  = ortho
        nodesep  = 0.35
        ranksep  = 0.6
        pad      = 0.2
        bgcolor  = "white"
    ]
    node [fontname="Helvetica" fontsize=8 style=filled shape=box margin="0.08,0.04"]
    edge [fontname="Helvetica" fontsize=7 arrowhead=normal color="#555555"]

    /* ── External stub (incoming) ───────────────────────────────── */
    cli_main [label="cli/main.py\n← CLI" fillcolor="#f4b8d4" fontcolor="#7a1545"]

    /* ── Ingest cluster ─────────────────────────────────────────── */
    subgraph cluster_ingest {

        label     = "Ingest  (llvmanim/ingest/)"
        style     = filled
        fillcolor = "#d5f5e3"
        color     = "#1e8449"
        margin    = 8
        labeljust = l

        in_trace [label="trace.json\n(--import-trace)"
                  fillcolor="#fef0bc" fontcolor="#9a6f00" shape=note]
        in_meta  [label="analysis_metadata.json\n(--import-analysis-metadata)"
                  fillcolor="#fef0bc" fontcolor="#9a6f00" shape=note]
        in_edges [label="cfg_edges.json\n(--import-cfg-edges)"
                  fillcolor="#fef0bc" fontcolor="#9a6f00" shape=note]

        trace_io    [label="load_trace()\ntrace_io.py"
                     fillcolor="#27ae60" fontcolor="white"]
        meta_io     [label="load_analysis_metadata()\nanalysis_metadata_io.py"
                     fillcolor="#27ae60" fontcolor="white"]
        cfg_edge_io [label="load_cfg_edges()\ncfg_edge_io.py"
                     fillcolor="#27ae60" fontcolor="white"]

        in_trace -> trace_io
        in_meta  -> meta_io
        in_edges -> cfg_edge_io
    }

    /* ── Data output nodes ──────────────────────────────────────── */
    trace_overlay [label="TraceOverlay\n(or auto-derived)" fillcolor="#f5cba7" fontcolor="#ca6f1e" shape=note]
    block_meta    [label="BlockMetadata"                   fillcolor="#f5cba7" fontcolor="#ca6f1e" shape=note]
    cfg_edges_d   [label="cfg_edges\n(override)"           fillcolor="#f5cba7" fontcolor="#ca6f1e" shape=note]

    /* ── External stub (outgoing) ───────────────────────────────── */
    build_sg [label="build_scene_graph()\n→ Transform" fillcolor="#f5cba7" fontcolor="#ca6f1e"]

    /* ── Edges ──────────────────────────────────────────────────── */
    cli_main -> in_trace [minlen=1]
    cli_main -> in_meta  [minlen=1]
    cli_main -> in_edges [minlen=1]

    trace_io    -> trace_overlay [minlen=1 style=dashed arrowhead=open]
    trace_overlay -> build_sg    [minlen=1 style=dashed arrowhead=open]
    meta_io     -> block_meta    [minlen=1]
    block_meta  -> build_sg      [minlen=1]
    cfg_edge_io -> cfg_edges_d   [minlen=1 style=dashed arrowhead=open]
    cfg_edges_d -> build_sg      [minlen=1 style=dashed arrowhead=open]
}
