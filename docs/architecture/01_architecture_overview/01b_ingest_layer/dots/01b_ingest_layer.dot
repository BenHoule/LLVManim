/**
 * 01b_ingest_layer.dot  (composed)
 *
 * Full Ingest layer detail.  Composed from the three subgraphs:
 *
 *   01b1_ir_parsing.dot       — parse_module_to_events
 *   01b2_dot_layout.dot       — compute_dot_layout
 *   01b3_supplemental_io.dot  — load_trace / load_analysis_metadata / load_cfg_edges
 *
 * Key source files:
 *   src/llvmanim/ingest/llvm_events.py          — parse_module_to_events()
 *   src/llvmanim/ingest/dot_layout.py           — compute_dot_layout()
 *   src/llvmanim/ingest/trace_io.py             — load_trace()
 *   src/llvmanim/ingest/analysis_metadata_io.py — load_analysis_metadata()
 *   src/llvmanim/ingest/cfg_edge_io.py          — load_cfg_edges()
 *
 * Render:
 *   dot -Tpdf 01b_ingest_layer.dot -o ../01b_ingest_layer.pdf
 */
digraph ingest_layer {
    graph [
        rankdir  = LR
        fontname = "Helvetica" fontsize = 10
        label    = "Ingest Layer  (llvmanim/ingest/,  composed)"
        labelloc = t
        splines  = ortho
        nodesep  = 0.35
        ranksep  = 0.6
        pad      = 0.2
        bgcolor  = "white"
    ]
    node [fontname="Helvetica" fontsize=8 style=filled shape=box margin="0.08,0.04"]
    edge [fontname="Helvetica" fontsize=7 arrowhead=normal color="#555555"]

    /* ── Shared entry / exit stubs ──────────────────────────────── */
    cli_main     [label="cli/main.py\n← CLI"               fillcolor="#f4b8d4" fontcolor="#7a1545"]
    build_sg     [label="build_scene_graph()\n→ Transform"  fillcolor="#f5cba7" fontcolor="#ca6f1e"]
    cfg_renderer [label="CFGRenderer\n→ Render"             fillcolor="#a9cce3" fontcolor="#1a5276"]
    gviz_export  [label="graphviz_export\n→ Render"         fillcolor="#a9cce3" fontcolor="#1a5276"]

    /* ══════════════════════════════════════════════════════════════
       IR PARSING
       source: 01b1_ir_parsing.dot
    ══════════════════════════════════════════════════════════════ */
    subgraph cluster_ir_parsing {

        label     = "IR Parsing  ·  llvm_events.py"
        style     = filled
        fillcolor = "#d5f5e3"
        color     = "#1e8449"
        margin    = 8
        labeljust = l

        in_ll        [label=".ll file" fillcolor="#fef0bc" fontcolor="#9a6f00" shape=note]
        parse_events [label="parse_module_to_events()\nllvm_events.py"
                      fillcolor="#27ae60" fontcolor="white"]
        llvmlite     [label="llvmlite\n(3rd party)" fillcolor="#bdc3c7" fontcolor="#2c3e50"]
        pes          [label="ProgramEventStream" fillcolor="#f5cba7" fontcolor="#ca6f1e" shape=note]

        in_ll -> parse_events
        parse_events -> pes
        parse_events -> llvmlite [style=dashed arrowhead=open xlabel="«import»" fontcolor="#2c3e50" color="#999999"]
    }

    /* ══════════════════════════════════════════════════════════════
       DOT LAYOUT
       source: 01b2_dot_layout.dot
    ══════════════════════════════════════════════════════════════ */
    subgraph cluster_dot_layout {

        label     = "DOT Layout  ·  dot_layout.py"
        style     = filled
        fillcolor = "#d5f5e3"
        color     = "#1e8449"
        margin    = 8
        labeljust = l

        dot_layout [label="compute_dot_layout()\ndot_layout.py"
                    fillcolor="#27ae60" fontcolor="white"]
        graphviz   [label="graphviz\n(3rd party)" fillcolor="#bdc3c7" fontcolor="#2c3e50"]
        in_dot     [label=".dot file" fillcolor="#fef0bc" fontcolor="#9a6f00" shape=note]

        in_dot -> dot_layout
        dot_layout -> graphviz [style=dashed arrowhead=open xlabel="«import»" fontcolor="#2c3e50" color="#999999"]
    }

    /* ══════════════════════════════════════════════════════════════
       SUPPLEMENTAL I/O
       source: 01b3_supplemental_io.dot
    ══════════════════════════════════════════════════════════════ */
    subgraph cluster_supplemental_io {

        label     = "Supplemental I/O\ntrace_io.py · analysis_metadata_io.py · cfg_edge_io.py"
        style     = filled
        fillcolor = "#d5f5e3"
        color     = "#1e8449"
        margin    = 8
        labeljust = l

        in_trace [label="trace.json\n(--import-trace)"
                  fillcolor="#fef0bc" fontcolor="#9a6f00" shape=note]
        in_meta  [label="analysis_metadata.json\n(--import-analysis-metadata)"
                  fillcolor="#fef0bc" fontcolor="#9a6f00" shape=note]
        in_edges [label="cfg_edges.json\n(--import-cfg-edges)"
                  fillcolor="#fef0bc" fontcolor="#9a6f00" shape=note]

        trace_io    [label="load_trace()\ntrace_io.py"
                     fillcolor="#27ae60" fontcolor="white"]
        meta_io     [label="load_analysis_metadata()\nanalysis_metadata_io.py"
                     fillcolor="#27ae60" fontcolor="white"]
        cfg_edge_io [label="load_cfg_edges()\ncfg_edge_io.py"
                     fillcolor="#27ae60" fontcolor="white"]

        in_trace -> trace_io
        in_meta  -> meta_io
        in_edges -> cfg_edge_io
    }

    /* ── Cross: CLI → IR parsing ────────────────────────────────── */
    cli_main -> in_ll [minlen=1]

    /* ── Cross: IR parsing → ProgramEventStream → Transform ──── */
    pes          -> build_sg [minlen=1]

    /* ── Cross: CLI → DOT layout ────────────────────────────────── */
    cli_main -> in_dot [minlen=1]

    /* ── Cross: DOT layout → output stubs ───────────────────────── */
    dot_layout_data [label="DotLayout" fillcolor="#a9cce3" fontcolor="#1a5276" shape=note]
    draw_flag       [label="--draw"    fillcolor="#a9cce3" fontcolor="#1a5276" shape=note]
    dot_layout -> dot_layout_data [minlen=1]
    dot_layout_data -> cfg_renderer [minlen=1]
    dot_layout -> draw_flag   [minlen=1]
    draw_flag  -> gviz_export [minlen=1]

    /* ── Cross: CLI → supplemental file inputs ──────────────────── */
    cli_main -> in_trace [minlen=1]
    cli_main -> in_meta  [minlen=1]
    cli_main -> in_edges [minlen=1]

    /* ── Cross: supplemental loaders → output stubs ─────────────── */
    trace_overlay [label="TraceOverlay\n(or auto-derived)" fillcolor="#f5cba7" fontcolor="#ca6f1e" shape=note]
    trace_io    -> trace_overlay [minlen=1 style=dashed arrowhead=open]
    trace_overlay -> build_sg    [minlen=1 style=dashed arrowhead=open]
    block_meta  [label="BlockMetadata" fillcolor="#f5cba7" fontcolor="#ca6f1e" shape=note]
    cfg_edges_d [label="cfg_edges\n(override)" fillcolor="#f5cba7" fontcolor="#ca6f1e" shape=note]
    meta_io     -> block_meta  [minlen=1]
    block_meta  -> build_sg    [minlen=1]
    cfg_edge_io -> cfg_edges_d [minlen=1 style=dashed arrowhead=open]
    cfg_edges_d -> build_sg    [minlen=1 style=dashed arrowhead=open]

    /* ── Ordering: force clusters top-to-bottom ────────────────── */
    parse_events -> dot_layout  [style=invis]
    dot_layout   -> trace_io    [style=invis]
}
