/**
 * 01c1_stack_build.dot
 *
 * Extracted subgraph: scene-graph build from 01c_transform_layer.
 * build_scene_graph() converts a ProgramEventStream into a SceneGraph
 * of AnimationCommands.  derive_cfg_trace() may also run to produce
 * a TraceOverlay (auto-derived or fused from a loaded trace file).
 *
 * Render:
 *   dot -Tpdf 01c1_stack_build.dot -o ../01c1_stack_build.pdf
 */
digraph scene_build {
    graph [
        rankdir  = LR
        fontname = "Helvetica" fontsize = 10
        label    = "Transform: Scene-Graph Build"
        labelloc = t
        splines  = ortho
        nodesep  = 0.5
        ranksep  = 0.6
        pad      = 0.2
        bgcolor  = "white"
    ]
    node [fontname="Helvetica" fontsize=8 style=filled shape=box margin="0.08,0.04"]
    edge [fontname="Helvetica" fontsize=7 arrowhead=normal color="#555555"]

    /* ── Ingest stub ────────────────────────────────────────────── */
    parse_events [label="parse_module_to_events()\n← Ingest" fillcolor="#a9dfbf" fontcolor="#1e8449"]

    /* ── Data nodes (input) ─────────────────────────────────────── */
    pes [label="ProgramEventStream" fillcolor="#f5cba7" fontcolor="#ca6f1e" shape=note]

    /* ── Transform cluster ──────────────────────────────────────── */
    subgraph cluster_transform {

        label     = "Transform  (llvmanim/transform/)"
        style     = filled
        fillcolor = "#fdebd0"
        color     = "#ca6f1e"
        margin    = 8
        labeljust = l

        derive_trace  [label="derive_cfg_trace()\ntrace.py"
                       fillcolor="#e67e22" fontcolor="white"]
        trace_overlay [label="TraceOverlay" fillcolor="#f5cba7" fontcolor="#ca6f1e" shape=note]
        build_scene   [label="build_scene_graph()\nscene.py"
                       fillcolor="#e67e22" fontcolor="white"]

        derive_trace  -> trace_overlay
        trace_overlay -> build_scene
    }

    /* ── Data nodes (output) ────────────────────────────────────── */
    scene_graph [label="SceneGraph" fillcolor="#a9cce3" fontcolor="#1a5276" shape=note]
    json_flag   [label="--json"     fillcolor="#a9cce3" fontcolor="#1a5276" shape=note]

    /* ── Render stubs ───────────────────────────────────────────── */
    renderer    [label="→ Render"              fillcolor="#a9cce3" fontcolor="#1a5276"]
    json_export [label="json_export\n→ Render" fillcolor="#a9cce3" fontcolor="#1a5276"]

    /* ── Main path (top): PES → build_scene → render ────────────── */
    parse_events -> pes          [weight=10]
    pes          -> build_scene  [weight=10 minlen=3]
    build_scene  -> scene_graph  [weight=10]
    scene_graph  -> renderer     [weight=10]
    build_scene  -> json_flag
    json_flag    -> json_export

    /* ── Optional CFG path (bottom): PES → derive ───────────────── */
    pes -> derive_trace [style=dashed arrowhead=open]
}
