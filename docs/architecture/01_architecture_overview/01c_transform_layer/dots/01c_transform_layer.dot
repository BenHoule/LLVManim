/**
 * 01c_transform_layer.dot  (composed)
 *
 * Full Transform layer detail.  Composed from the two subgraphs:
 *
 *   01c1_stack_build.dot  — scene-graph build
 *   01c2_cfg_build.dot    — CFG trace derivation
 *
 * Key source files:
 *   src/llvmanim/transform/scene.py — build_scene_graph()
 *   src/llvmanim/transform/trace.py — derive_cfg_trace()
 *
 * Render:
 *   dot -Tpdf 01c_transform_layer.dot -o ../01c_transform_layer.pdf
 */
digraph transform_layer {
    graph [
        rankdir  = LR
        fontname = "Helvetica" fontsize = 10
        label    = "Transform Layer  (llvmanim/transform/,  composed)"
        labelloc = t
        splines  = ortho
        nodesep  = 0.5
        ranksep  = 0.6
        pad      = 0.2
        bgcolor  = "white"
    ]
    node [fontname="Helvetica" fontsize=8 style=filled shape=box margin="0.08,0.04"]
    edge [fontname="Helvetica" fontsize=7 arrowhead=normal color="#555555"]

    /* ── Ingest stubs ───────────────────────────────────────────── */
    parse_events [label="parse_module_to_events()\n← Ingest" fillcolor="#a9dfbf" fontcolor="#1e8449"]
    trace_io     [label="load_trace()\n← Ingest"             fillcolor="#a9dfbf" fontcolor="#1e8449"]

    /* ── Render stubs ───────────────────────────────────────────── */
    renderer    [label="→ Render"              fillcolor="#a9cce3" fontcolor="#1a5276"]
    json_export [label="json_export\n→ Render" fillcolor="#a9cce3" fontcolor="#1a5276"]

    /* ══════════════════════════════════════════════════════════════
       SCENE-GRAPH BUILD
       source: 01c1_stack_build.dot
    ══════════════════════════════════════════════════════════════ */
    subgraph cluster_scene_build {

        label     = "Scene-Graph Build  ·  scene.py"
        style     = filled
        fillcolor = "#fdebd0"
        color     = "#ca6f1e"
        margin    = 8
        labeljust = l

        build_scene [label="build_scene_graph()\nscene.py"
                     fillcolor="#e67e22" fontcolor="white"]
    }

    /* ══════════════════════════════════════════════════════════════
       TRACE DERIVATION
       source: 01c2_cfg_build.dot
    ══════════════════════════════════════════════════════════════ */
    subgraph cluster_trace_derivation {

        label     = "Trace Derivation  ·  trace.py"
        style     = filled
        fillcolor = "#fdebd0"
        color     = "#ca6f1e"
        margin    = 8
        labeljust = l

        derive_trace [label="derive_cfg_trace()\ntrace.py"
                      fillcolor="#e67e22" fontcolor="white"]
    }

    /* ── Data nodes ─────────────────────────────────────────────── */
    pes            [label="ProgramEventStream"        fillcolor="#f5cba7" fontcolor="#ca6f1e" shape=note]
    trace_override [label="TraceOverlay\n(override)"  fillcolor="#f5cba7" fontcolor="#ca6f1e" shape=note]
    trace_overlay  [label="TraceOverlay"              fillcolor="#f5cba7" fontcolor="#ca6f1e" shape=note]
    scene_graph    [label="SceneGraph"                fillcolor="#a9cce3" fontcolor="#1a5276" shape=note]
    json_flag      [label="--json"                    fillcolor="#a9cce3" fontcolor="#1a5276" shape=note]

    /* ── Main path (top row): ingest → PES → build → render ────── */
    parse_events -> pes          [weight=10]
    pes          -> build_scene  [weight=10 minlen=3]
    build_scene  -> scene_graph  [weight=10]
    scene_graph  -> renderer     [weight=10]
    build_scene  -> json_flag
    json_flag    -> json_export

    /* ── CFG path (bottom row): PES → derive → overlay → build ── */
    pes            -> derive_trace
    trace_io       -> trace_override [style=dashed arrowhead=open]
    trace_override -> derive_trace   [style=dashed arrowhead=open]
    derive_trace   -> trace_overlay
    trace_overlay  -> build_scene
}
