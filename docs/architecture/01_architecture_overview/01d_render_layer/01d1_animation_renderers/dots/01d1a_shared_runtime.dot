/**
 * 01d1a_shared_runtime.dot  (subgraph)
 *
 * Shared render runtime: CommandDrivenScene base class and
 * the Manim CE dependency that drives frame-by-frame output.
 *
 * Render:
 *   dot -Tpdf 01d1a_shared_runtime.dot -o ../01d1a_shared_runtime.pdf
 */
digraph shared_runtime {
    graph [
        rankdir  = LR
        fontname = "Helvetica" fontsize = 10
        label    = "Shared Runtime  (01d1a)"
        labelloc = t
        splines  = ortho
        nodesep  = 0.5
        ranksep  = 0.6
        pad      = 0.2
        bgcolor  = "white"
    ]
    node [fontname="Helvetica" fontsize=8 style=filled shape=box margin="0.08,0.04"]
    edge [fontname="Helvetica" fontsize=7 arrowhead=normal color="#555555"]

    /* ── Renderer stubs ─────────────────────────────────────────── */
    stack_renderer [label="StackRenderer\n← stack_renderer.py" fillcolor="#a9cce3" fontcolor="#1a5276"]
    cfg_renderer   [label="CFGRenderer\n← cfg_renderer.py"     fillcolor="#a9cce3" fontcolor="#1a5276"]

    /* ── Output ─────────────────────────────────────────────────── */
    out_anim [label="animation\n(MP4 / GIF)" fillcolor="#e74c3c" fontcolor="white" shape=note]

    /* ── Render cluster ─────────────────────────────────────────── */
    subgraph cluster_render {

        label     = "Render"
        style     = filled
        fillcolor = "#d4e6f1"
        color     = "#1a5276"
        margin    = 8
        labeljust = l

        cmd_scene [label="CommandDrivenScene\ncommand_driven_scene.py"
                   fillcolor="#2980b9" fontcolor="white"]
        manim_ce  [label="Manim CE\n(3rd party)"
                   fillcolor="#bdc3c7" fontcolor="#2c3e50"]
    }

    /* ── Edges ──────────────────────────────────────────────────── */
    stack_renderer -> cmd_scene [arrowhead=empty]
    cfg_renderer   -> cmd_scene [arrowhead=empty]
    cmd_scene      -> manim_ce
    manim_ce       -> out_anim
}
