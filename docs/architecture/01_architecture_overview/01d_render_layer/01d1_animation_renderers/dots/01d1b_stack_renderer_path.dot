/**
 * 01d1b_stack_renderer_path.dot  (subgraph)
 *
 * StackRenderer path: SceneGraph flows into StackRenderer, which
 * imports ssa_formatting for rich-SSA colouring, extends
 * CommandDrivenScene, and drives animation through Manim CE.
 *
 * Render:
 *   dot -Tpdf 01d1b_stack_renderer_path.dot -o ../01d1b_stack_renderer_path.pdf
 */
digraph stack_renderer_path {
    graph [
        rankdir  = LR
        fontname = "Helvetica" fontsize = 10
        label    = "Stack Renderer Path  (01d1b)"
        labelloc = t
        splines  = ortho
        nodesep  = 0.5
        ranksep  = 0.6
        pad      = 0.2
        bgcolor  = "white"
    ]
    node [fontname="Helvetica" fontsize=8 style=filled shape=box margin="0.08,0.04"]
    edge [fontname="Helvetica" fontsize=7 arrowhead=normal color="#555555"]

    /* ── Transform stub ─────────────────────────────────────────── */
    build_sg [label="build_scene_graph()\n← Transform" fillcolor="#f5cba7" fontcolor="#ca6f1e"]

    /* ── Data node ──────────────────────────────────────────────── */
    scene_graph [label="SceneGraph" fillcolor="#a9cce3" fontcolor="#1a5276" shape=note]

    /* ── Output ─────────────────────────────────────────────────── */
    out_anim [label="stack animation\n(MP4 / GIF)" fillcolor="#e74c3c" fontcolor="white" shape=note]

    /* ── Render cluster ─────────────────────────────────────────── */
    subgraph cluster_render {

        label     = "Render"
        style     = filled
        fillcolor = "#d4e6f1"
        color     = "#1a5276"
        margin    = 8
        labeljust = l

        stack_renderer [label="StackRenderer\nstack_renderer.py"
                        fillcolor="#2980b9" fontcolor="white"]
        ssa_fmt        [label="ssa_formatting.py"
                        fillcolor="#2980b9" fontcolor="white"]
        cmd_scene      [label="CommandDrivenScene\ncommand_driven_scene.py"
                        fillcolor="#2980b9" fontcolor="white"]
        manim_ce       [label="Manim CE\n(3rd party)"
                        fillcolor="#bdc3c7" fontcolor="#2c3e50"]
    }

    /* ── Edges ──────────────────────────────────────────────────── */
    build_sg       -> scene_graph    [weight=10]
    scene_graph    -> stack_renderer [weight=10]
    stack_renderer -> ssa_fmt        [style=dashed arrowhead=open xlabel="«import»" fontcolor="#2c3e50" color="#999999"]
    stack_renderer -> cmd_scene      [arrowhead=empty weight=10]
    cmd_scene      -> manim_ce       [weight=10]
    manim_ce       -> out_anim       [weight=10]
}
