/**
 * 01d1_animation_renderers.dot  (composed)
 *
 * Animation renderer subsystem. Composed from three subgraphs:
 *
 *   01d1a_shared_runtime.dot        — CommandDrivenScene + Manim CE
 *   01d1b_stack_renderer_path.dot   — StackRenderer + ssa_formatting
 *   01d1c_cfg_renderer_path.dot     — CFGRenderer + cfg_animation_scene
 *
 * Render:
 *   dot -Tpdf 01d1_animation_renderers.dot -o ../01d1_animation_renderers.pdf
 */
digraph animation_renderers {
    graph [
        rankdir  = LR
        fontname = "Helvetica" fontsize = 10
        label    = "Render: Animation Renderers  (composed)"
        labelloc = t
        splines  = ortho
        nodesep  = 0.5
        ranksep  = 0.6
        pad      = 0.2
        bgcolor  = "white"
    ]
    node [fontname="Helvetica" fontsize=8 style=filled shape=box margin="0.08,0.04"]
    edge [fontname="Helvetica" fontsize=7 arrowhead=normal color="#555555"]

    /* ── Transform / Ingest stubs ───────────────────────────────── */
    build_sg   [label="build_scene_graph()\n← Transform" fillcolor="#f5cba7" fontcolor="#ca6f1e"]
    dot_layout [label="compute_dot_layout()\n← Ingest"   fillcolor="#a9dfbf" fontcolor="#1e8449"]
    out_anim   [label="animation\n(MP4 / GIF)" fillcolor="#e74c3c" fontcolor="white" shape=note]

    /* ── Data nodes ─────────────────────────────────────────────── */
    scene_graph     [label="SceneGraph" fillcolor="#a9cce3" fontcolor="#1a5276" shape=note]
    dot_layout_data [label="DotLayout"  fillcolor="#a9cce3" fontcolor="#1a5276" shape=note]

    /* ══════════════════════════════════════════════════════════════
       SHARED RUNTIME
       source: 01d1a_shared_runtime.dot
    ══════════════════════════════════════════════════════════════ */
    subgraph cluster_shared_runtime {

        label     = "Shared Runtime  ·  command_driven_scene.py"
        style     = filled
        fillcolor = "#d4e6f1"
        color     = "#1a5276"
        margin    = 8
        labeljust = l

        cmd_scene [label="CommandDrivenScene\ncommand_driven_scene.py"
                   fillcolor="#2980b9" fontcolor="white"]
        manim_ce  [label="Manim CE\n(3rd party)"
                   fillcolor="#bdc3c7" fontcolor="#2c3e50"]

        cmd_scene -> manim_ce
    }

    /* ══════════════════════════════════════════════════════════════
       STACK RENDERER PATH
       source: 01d1b_stack_renderer_path.dot
    ══════════════════════════════════════════════════════════════ */
    subgraph cluster_stack_renderer_path {

        label     = "Stack Renderer Path  ·  stack_renderer.py"
        style     = filled
        fillcolor = "#d4e6f1"
        color     = "#1a5276"
        margin    = 8
        labeljust = l

        stack_renderer [label="StackRenderer\nstack_renderer.py"
                        fillcolor="#2980b9" fontcolor="white"]
        ssa_fmt        [label="ssa_formatting.py"
                        fillcolor="#2980b9" fontcolor="white"]
    }

    /* ══════════════════════════════════════════════════════════════
       CFG RENDERER PATH
       source: 01d1c_cfg_renderer_path.dot
    ══════════════════════════════════════════════════════════════ */
    subgraph cluster_cfg_renderer_path {

        label     = "CFG Renderer Path  ·  cfg_renderer.py"
        style     = filled
        fillcolor = "#d4e6f1"
        color     = "#1a5276"
        margin    = 8
        labeljust = l

        cfg_renderer   [label="CFGRenderer\ncfg_renderer.py"
                        fillcolor="#2980b9" fontcolor="white"]
        cfg_anim_scene [label="cfg_animation_scene.py"
                        fillcolor="#2980b9" fontcolor="white"]
    }

    /* ── Data flow ──────────────────────────────────────────────── */
    build_sg        -> scene_graph     [weight=10]
    dot_layout      -> dot_layout_data
    scene_graph     -> stack_renderer  [weight=10]
    scene_graph     -> cfg_renderer
    dot_layout_data -> cfg_renderer

    /* ── Import edges ───────────────────────────────────────────── */
    stack_renderer -> ssa_fmt        [style=dashed arrowhead=open xlabel="«import»" fontcolor="#2c3e50" color="#999999"]
    cfg_renderer   -> cfg_anim_scene [style=dashed arrowhead=open label="«import»" fontcolor="#2c3e50" color="#999999"]

    /* ── Extends edges ──────────────────────────────────────────── */
    stack_renderer -> cmd_scene [arrowhead=empty]
    cfg_renderer   -> cmd_scene [arrowhead=empty]

    /* ── Output ─────────────────────────────────────────────────── */
    manim_ce -> out_anim
}
