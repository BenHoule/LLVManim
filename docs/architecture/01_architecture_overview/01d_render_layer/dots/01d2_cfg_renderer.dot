/**
 * 01d2_cfg_renderer.dot  (subgraph)
 *
 * Detail for the CFG renderer path: cfg_renderer.py and
 * cfg_animation_scene.py working together to produce the animated
 * control-flow graph visualisation.
 *
 * Render:
 *   dot -Tpdf 01d2_cfg_renderer.dot -o ../01d2_cfg_renderer.pdf
 */
digraph cfg_renderer_detail {
    graph [
        rankdir  = LR
        fontname = "Helvetica" fontsize = 10
        label    = "CFG Renderer  (01d2)"
        labelloc = t
        splines  = ortho
        nodesep  = 0.5
        ranksep  = 0.6
        pad      = 0.2
        bgcolor  = "white"
    ]
    node [fontname="Helvetica" fontsize=8 style=filled shape=box margin="0.08,0.04"]
    edge [fontname="Helvetica" fontsize=7 arrowhead=normal color="#555555"]

    /* ── External stubs ─────────────────────────────────────────── */
    dot_layout [label="compute_dot_layout()\n← Ingest" fillcolor="#a9dfbf" fontcolor="#1e8449"]
    manim_ce   [label="Manim CE\n(3rd party)"          fillcolor="#bdc3c7" fontcolor="#2c3e50"]

    /* ── Data nodes ─────────────────────────────────────────────── */
    scene_graph     [label="SceneGraph"  fillcolor="#a9cce3" fontcolor="#1a5276" shape=note]
    dot_layout_data [label="DotLayout"   fillcolor="#a9cce3" fontcolor="#1a5276" shape=note]

    /* ── Render cluster ─────────────────────────────────────────── */
    subgraph cluster_render {

        label     = "Render"
        style     = filled
        fillcolor = "#d4e6f1"
        color     = "#1a5276"
        margin    = 8
        labeljust = l

        cfg_renderer   [label="CFGRenderer\ncfg_renderer.py"   fillcolor="#2980b9" fontcolor="white"]
        cfg_anim_scene [label="cfg_animation_scene.py"         fillcolor="#2980b9" fontcolor="white"]
    }

    /* ── Edges ──────────────────────────────────────────────────── */
    scene_graph     -> cfg_renderer    [weight=10]
    dot_layout      -> dot_layout_data [constraint=false]
    dot_layout_data -> cfg_renderer
    cfg_renderer    -> cfg_anim_scene  [style=dashed arrowhead=open label="«import»" fontcolor="#2c3e50" color="#999999"]
    cfg_renderer    -> manim_ce        [style=dashed arrowhead=open xlabel="«import»" fontcolor="#2c3e50" color="#999999"]
    cfg_anim_scene  -> manim_ce        [style=dashed arrowhead=open label="«import»" fontcolor="#2c3e50" color="#999999"]
}
