/**
 * 01d_render_layer.dot  (composed)
 *
 * Full Render layer detail. Composed from the three subgraphs:
 *
 *   01d1_animation_renderers.dot — animation renderer runtime and mode paths
 *   01d2_cfg_renderer.dot        — cfg_animation_scene.py detail
 *   01d3_export.dot              — JSON and DOT/PNG export paths
 */
digraph render_layer {
    graph [
        rankdir  = LR
        fontname = "Helvetica" fontsize = 11
        label    = "Render Layer  (llvmanim/render/,  composed)"
        labelloc = t
        splines  = ortho
        nodesep  = 0.35
        ranksep  = 0.75
        pad      = 0.3
        bgcolor  = "white"
        size     = "10.5,7.0"
        ratio    = compress
    ]
    node [fontname="Helvetica" fontsize=9 style=filled shape=box margin="0.12,0.06"]
    edge [fontname="Helvetica" fontsize=8 arrowhead=open color="#555555"]

    /* ── Shared ingest / transform stubs ────────────────────────── */
    build_sg      [label="build_scene_graph()\n← Transform" fillcolor="#f5cba7" fontcolor="#ca6f1e"]
    dot_layout    [label="compute_dot_layout()\n← Ingest"   fillcolor="#a9dfbf" fontcolor="#1e8449"]
    display_lines [label="build_display_lines()\n← Ingest"  fillcolor="#a9dfbf" fontcolor="#1e8449"]

    /* ── Outputs ─────────────────────────────────────────────────── */
    out_anim [label="animation\n(MP4 / GIF)" fillcolor="#e74c3c" fontcolor="white" shape=note]
    out_json [label="*_scene_graph.json" fillcolor="#e74c3c" fontcolor="white" shape=note]
    out_dot  [label="cfg_*.dot / cfg_*.png" fillcolor="#e74c3c" fontcolor="white" shape=note]

    /* ══════════════════════════════════════════════════════════════
       ANIMATION RENDERERS
       source: 01d1_animation_renderers.dot
    ══════════════════════════════════════════════════════════════ */
    subgraph cluster_animation_renderers {

        label     = "Animation Renderers  ·  command_driven_scene.py + stack/cfg renderer paths"
        style     = filled
        fillcolor = "#d4e6f1"
        color     = "#1a5276"
        margin    = 10
        labeljust = l

        cmd_scene      [label="CommandDrivenScene\ncommand_driven_scene.py"
                        fillcolor="#2980b9" fontcolor="white"]
        stack_renderer [label="StackRenderer\nstack_renderer.py"
                        fillcolor="#2980b9" fontcolor="white"]
        cfg_renderer   [label="CFGRenderer\ncfg_renderer.py"
                        fillcolor="#2980b9" fontcolor="white"]
        ssa_fmt        [label="ssa_formatting.py\n(SSA register colours)"
                        fillcolor="#2980b9" fontcolor="white"]
        manim_ce       [label="Manim Community Edition\n(3rd party)"
                        fillcolor="#bdc3c7" fontcolor="#2c3e50"]
    }

    /* ══════════════════════════════════════════════════════════════
       CFG ANIMATION SCENE DETAIL
       source: 01d2_cfg_renderer.dot
    ══════════════════════════════════════════════════════════════ */
    subgraph cluster_cfg_anim_scene_detail {

        label     = "CFG Geometry Helpers  ·  cfg_animation_scene.py"
        style     = filled
        fillcolor = "#d4e6f1"
        color     = "#1a5276"
        margin    = 10
        labeljust = l

        cfg_anim_scene [label="cfg_animation_scene.py\n(_CoordMapper, build helpers)"
                        fillcolor="#2980b9" fontcolor="white"]
    }

    /* ══════════════════════════════════════════════════════════════
       EXPORT PATHS
       source: 01d3_export.dot
    ══════════════════════════════════════════════════════════════ */
    subgraph cluster_export_paths {

        label     = "Export Paths  ·  json_export.py + graphviz_export.py"
        style     = filled
        fillcolor = "#d4e6f1"
        color     = "#1a5276"
        margin    = 10
        labeljust = l

        json_export [label="json_export.py\n(export_scene_graph_json)"
                     fillcolor="#2980b9" fontcolor="white"]
        gviz_export [label="graphviz_export.py\n(export_cfg_dot/png)"
                     fillcolor="#2980b9" fontcolor="white"]
        graphviz    [label="graphviz\n(3rd party)" fillcolor="#bdc3c7" fontcolor="#2c3e50"]
    }

    /* ── Cross: transform/ingest → renderers ───────────────────── */
    build_sg      -> stack_renderer [xlabel="SceneGraph"]
    build_sg      -> cfg_renderer   [xlabel="SceneGraph"]
    display_lines -> stack_renderer [style=dashed xlabel="import"]
    dot_layout    -> cfg_renderer   [xlabel="DotLayout"]

    /* ── Cross: internal dependencies ───────────────────────────── */
    stack_renderer -> ssa_fmt        [style=dashed xlabel="import\n(rich-ssa)" color="#999999"]
    cfg_renderer   -> cfg_anim_scene [style=dashed xlabel="import" color="#999999"]
    cfg_anim_scene -> dot_layout     [style=dashed xlabel="import\n(DotLayout types)" color="#999999"]
    cfg_anim_scene -> manim_ce       [style=dashed xlabel="import\n(Mobject API)" color="#999999"]

    /* ── Cross: inheritance + animation output ──────────────────── */
    stack_renderer -> cmd_scene [arrowhead=empty xlabel="extends"]
    cfg_renderer   -> cmd_scene [arrowhead=empty xlabel="extends"]
    cmd_scene      -> manim_ce
    manim_ce       -> out_anim

    /* ── Cross: export paths ────────────────────────────────────── */
    build_sg    -> json_export [xlabel="--json"]
    json_export -> out_json

    dot_layout  -> gviz_export [xlabel="--draw"]
    gviz_export -> out_dot
    gviz_export -> graphviz [style=dashed xlabel="import" color="#999999"]
}
