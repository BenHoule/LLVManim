/**
 * 01d_render_layer.dot  (composed)
 *
 * Full Render layer detail. Composed from the three subgraphs:
 *
 *   01d1_animation_renderers.dot — animation renderer runtime and mode paths
 *   01d2_cfg_renderer.dot        — cfg_animation_scene.py detail
 *   01d3_export.dot              — JSON and DOT/PNG export paths
 *
 * Render:
 *   dot -Tpdf 01d_render_layer.dot -o ../01d_render_layer.pdf
 */
digraph render_layer {
    graph [
        rankdir  = LR
        fontname = "Helvetica" fontsize = 10
        label    = "Render Layer  (llvmanim/render/,  composed)"
        labelloc = t
        splines  = ortho
        nodesep  = 0.5
        ranksep  = 0.6
        pad      = 0.2
        bgcolor  = "white"
    ]
    node [fontname="Helvetica" fontsize=8 style=filled shape=box margin="0.08,0.04"]
    edge [fontname="Helvetica" fontsize=7 arrowhead=normal color="#555555"]

    /* ── Transform / Ingest stubs ───────────────────────────────── */
    build_sg   [label="build_scene_graph()\n← Transform" fillcolor="#f5cba7" fontcolor="#ca6f1e"]
    dot_layout [label="compute_dot_layout()\n← Ingest"   fillcolor="#a9dfbf" fontcolor="#1e8449"]

    /* ══════════════════════════════════════════════════════════════
       ANIMATION RENDERERS
       source: 01d1_animation_renderers.dot
    ══════════════════════════════════════════════════════════════ */
    subgraph cluster_animation_renderers {

        label     = "Animation Renderers"
        style     = filled
        fillcolor = "#d4e6f1"
        color     = "#1a5276"
        margin    = 8
        labeljust = l

        stack_renderer [label="StackRenderer\nstack_renderer.py"
                        fillcolor="#2980b9" fontcolor="white"]
        cfg_renderer   [label="CFGRenderer\ncfg_renderer.py"
                        fillcolor="#2980b9" fontcolor="white"]
        ssa_fmt        [label="ssa_formatting.py"
                        fillcolor="#2980b9" fontcolor="white"]
        cfg_anim_scene [label="cfg_animation_scene.py"
                        fillcolor="#2980b9" fontcolor="white"]
        cmd_scene      [label="CommandDrivenScene\ncommand_driven_scene.py"
                        fillcolor="#2980b9" fontcolor="white"]
        manim_ce       [label="Manim CE\n(3rd party)"
                        fillcolor="#bdc3c7" fontcolor="#2c3e50"]
        out_anim       [label="animation\n(MP4 / GIF)" fillcolor="#e74c3c" fontcolor="white" shape=note]

        stack_renderer -> ssa_fmt        [style=dashed arrowhead=open color="#999999"]
        cfg_renderer   -> cfg_anim_scene [style=dashed arrowhead=open color="#999999"]
        stack_renderer -> cmd_scene      [arrowhead=empty]
        cfg_renderer   -> cmd_scene      [arrowhead=empty]
        cmd_scene      -> manim_ce
        manim_ce       -> out_anim
    }

    /* ══════════════════════════════════════════════════════════════
       EXPORT PATHS
       source: 01d3_export.dot
    ══════════════════════════════════════════════════════════════ */
    subgraph cluster_export_paths {

        label     = "Export Paths"
        style     = filled
        fillcolor = "#d4e6f1"
        color     = "#1a5276"
        margin    = 8
        labeljust = l

        json_export [label="json_export.py"
                     fillcolor="#2980b9" fontcolor="white"]
        gviz_export [label="graphviz_export.py"
                     fillcolor="#2980b9" fontcolor="white"]
        graphviz    [label="graphviz\n(3rd party)" fillcolor="#bdc3c7" fontcolor="#2c3e50"]
        out_json    [label="*_scene_graph.json"    fillcolor="#e74c3c" fontcolor="white" shape=note]
        out_dot     [label="cfg_*.dot / cfg_*.png" fillcolor="#e74c3c" fontcolor="white" shape=note]

        gviz_export -> graphviz [style=dashed arrowhead=open xlabel="«import»" fontcolor="#2c3e50" color="#999999"]
        json_export -> out_json
        gviz_export -> out_dot
    }

    /* ── Data nodes ─────────────────────────────────────────────── */
    scene_graph     [label="SceneGraph"  fillcolor="#a9cce3" fontcolor="#1a5276" shape=note]
    dot_layout_data [label="DotLayout"   fillcolor="#a9cce3" fontcolor="#1a5276" shape=note]
    json_flag       [label="--json"      fillcolor="#a9cce3" fontcolor="#1a5276" shape=note]
    draw_flag       [label="--draw"      fillcolor="#a9cce3" fontcolor="#1a5276" shape=note]

    /* ── Animation data flow ────────────────────────────────────── */
    build_sg        -> scene_graph     [weight=10]
    scene_graph     -> stack_renderer  [weight=10]
    scene_graph     -> cfg_renderer
    dot_layout      -> dot_layout_data
    dot_layout_data -> cfg_renderer

    /* ── Export data flow ───────────────────────────────────────── */
    build_sg   -> json_flag
    json_flag  -> json_export
    dot_layout -> draw_flag
    draw_flag  -> gviz_export

    /* ── Ordering: animation cluster above export cluster ──────── */
    stack_renderer -> json_export [style=invis]
}
