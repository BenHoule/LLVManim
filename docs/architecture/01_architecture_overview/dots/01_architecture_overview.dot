/**
 * 01_architecture_overview.dot  (composed)
 *
 * Top-level architecture composed from layer subgraphs:
 *
 *   01a_cli_layer.dot
 *   01b_ingest_layer/01b_ingest_layer.dot
 *   01c_transform_layer/01c_transform_layer.dot
 *   01d_render_layer/01d_render_layer.dot
 *
 * Third-party import edges (llvmlite, graphviz, Manim CE) are
 * omitted here for clarity — see each layer subgraph for detail.
 *
 * Render:
 *   dot -Tpdf 01_architecture_overview.dot -o ../01_architecture_overview.pdf
 */
digraph architecture_overview {
    graph [
        rankdir  = LR
        fontname = "Helvetica" fontsize = 10
        label    = "LLVManim: Layer Architecture  (composed)"
        labelloc = t
        splines  = ortho
        nodesep  = 0.5
        ranksep  = 0.6
        pad      = 0.2
        bgcolor  = "white"
    ]
    node [fontname="Helvetica" fontsize=8 style=filled shape=box margin="0.08,0.04"]
    edge [fontname="Helvetica" fontsize=7 arrowhead=normal color="#555555"]

    /* ── File inputs ────────────────────────────────────────────── */
    input_ll  [label="input.ll\n(LLVM-IR file)"           fillcolor="#fef0bc" fontcolor="#9a6f00" shape=note]
    input_dot [label="layout.dot\n(optional pre-computed)" fillcolor="#fef0bc" fontcolor="#9a6f00" shape=note]

    /* ══════════════════════════════════════════════════════════════
       CLI LAYER
       source: 01a_cli_layer.dot
    ══════════════════════════════════════════════════════════════ */
    subgraph cluster_cli {

        label     = "CLI Layer  ·  llvmanim/cli/"
        style     = filled
        fillcolor = "#fce4ec"
        color     = "#7a1545"
        margin    = 8
        labeljust = l

        cli_main [label="main.py\nargparse dispatch"
                  fillcolor="#c0397e" fontcolor="white"]
    }

    /* ══════════════════════════════════════════════════════════════
       INGEST LAYER
       source: 01b_ingest_layer/01b_ingest_layer.dot
    ══════════════════════════════════════════════════════════════ */
    subgraph cluster_ingest {

        label     = "Ingest Layer  ·  llvmanim/ingest/"
        style     = filled
        fillcolor = "#d5f5e3"
        color     = "#1e8449"
        margin    = 8
        labeljust = l

        parse_events [label="parse_module_to_events()\nllvm_events.py"
                      fillcolor="#27ae60" fontcolor="white"]
        supplemental [label="load_trace()  ·  load_analysis_metadata()\nload_cfg_edges()  (supplemental I/O)"
                      fillcolor="#27ae60" fontcolor="white"]
        dot_layout   [label="compute_dot_layout()\ndot_layout.py"
                      fillcolor="#27ae60" fontcolor="white"]
    }

    /* ══════════════════════════════════════════════════════════════
       TRANSFORM LAYER
       source: 01c_transform_layer/01c_transform_layer.dot
    ══════════════════════════════════════════════════════════════ */
    subgraph cluster_transform {

        label     = "Transform Layer  ·  llvmanim/transform/"
        style     = filled
        fillcolor = "#fdebd0"
        color     = "#ca6f1e"
        margin    = 8
        labeljust = l

        derive_trace [label="derive_cfg_trace()\ntrace.py"
                      fillcolor="#e67e22" fontcolor="white"]
        build_scene  [label="build_scene_graph()\nscene.py"
                      fillcolor="#e67e22" fontcolor="white"]
    }

    /* ══════════════════════════════════════════════════════════════
       RENDER LAYER
       source: 01d_render_layer/01d_render_layer.dot
    ══════════════════════════════════════════════════════════════ */
    subgraph cluster_render {

        label     = "Render Layer  ·  llvmanim/render/"
        style     = filled
        fillcolor = "#d4e6f1"
        color     = "#1a5276"
        margin    = 8
        labeljust = l

        renderer    [label="animation renderers\n(stack + cfg + runtime)"
                     fillcolor="#2980b9" fontcolor="white"]
        json_export [label="json_export.py"
                     fillcolor="#2980b9" fontcolor="white"]
        gviz_export [label="graphviz_export.py"
                     fillcolor="#2980b9" fontcolor="white"]
        out_anim    [label="animation\n(MP4 / GIF)"    fillcolor="#e74c3c" fontcolor="white" shape=note]
        out_json    [label="*_scene_graph.json"         fillcolor="#e74c3c" fontcolor="white" shape=note]
        out_dot     [label="cfg_*.dot / cfg_*.png"      fillcolor="#e74c3c" fontcolor="white" shape=note]

        renderer    -> out_anim  [weight=10]
        json_export -> out_json  [weight=10]
        gviz_export -> out_dot   [weight=10]
    }

    /* ── Data nodes ─────────────────────────────────────────────── */
    pes         [label="ProgramEventStream" fillcolor="#f5cba7" fontcolor="#ca6f1e" shape=note]
    scene_graph [label="SceneGraph"         fillcolor="#a9cce3" fontcolor="#1a5276" shape=note]

    /* ── File inputs → CLI ──────────────────────────────────────── */
    input_ll  -> cli_main [weight=10]
    input_dot -> cli_main

    /* ── CLI → Ingest ───────────────────────────────────────────── */
    cli_main -> parse_events [weight=10]
    cli_main -> dot_layout
    cli_main -> supplemental

    /* ── Ingest → Transform (main path) ─────────────────────────── */
    parse_events -> pes          [weight=10]
    pes          -> derive_trace [weight=10]
    derive_trace -> build_scene  [weight=10]

    /* ── Ingest → Transform (side inputs) ───────────────────────── */
    supplemental -> derive_trace [style=dashed arrowhead=open]

    /* ── Transform → Render ─────────────────────────────────────── */
    build_scene -> scene_graph  [weight=10]
    scene_graph -> renderer     [weight=10]
    build_scene -> json_export
    scene_graph -> gviz_export

    /* ── Ordering ───────────────────────────────────────────────── */
    renderer -> json_export [style=invis]
}
