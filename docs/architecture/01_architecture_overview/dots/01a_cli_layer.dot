/**
 * 01a_cli_layer.dot
 *
 * CLI entry point and dispatch into ingest loaders/parsers.
 * File inputs flow into main.py, which dispatches to the
 * appropriate Ingest-layer functions.
 *
 * Render:
 *   dot -Tpdf 01a_cli_layer.dot -o ../01a_cli_layer.pdf
 */
digraph cli_layer {
    graph [
        rankdir  = LR
        fontname = "Helvetica" fontsize = 10
        label    = "CLI Layer  (llvmanim/cli/)"
        labelloc = t
        splines  = ortho
        nodesep  = 0.5
        ranksep  = 0.6
        pad      = 0.2
        bgcolor  = "white"
    ]
    node [fontname="Helvetica" fontsize=8 style=filled shape=box margin="0.08,0.04"]
    edge [fontname="Helvetica" fontsize=7 arrowhead=normal color="#555555"]

    /* ── File inputs ────────────────────────────────────────────── */
    input_ll  [label="input.ll\n(LLVM-IR file)"           fillcolor="#fef0bc" fontcolor="#9a6f00" shape=note]
    input_dot [label="layout.dot\n(optional pre-computed)" fillcolor="#fef0bc" fontcolor="#9a6f00" shape=note]

    /* ── CLI cluster ────────────────────────────────────────────── */
    subgraph cluster_cli {

        label     = "CLI  (llvmanim/cli/)"
        style     = filled
        fillcolor = "#fce4ec"
        color     = "#7a1545"
        margin    = 8
        labeljust = l

        cli_main [label="main.py\nargparse dispatch"
                  fillcolor="#c0397e" fontcolor="white"]
    }

    /* ── Ingest stubs ───────────────────────────────────────────── */
    parse_events [label="parse_module_to_events()\n→ Ingest" fillcolor="#a9dfbf" fontcolor="#1e8449"]
    dot_layout   [label="compute_dot_layout()\n→ Ingest"     fillcolor="#a9dfbf" fontcolor="#1e8449"]
    trace_io     [label="load_trace()\n→ Ingest"             fillcolor="#a9dfbf" fontcolor="#1e8449"]
    meta_io      [label="load_analysis_metadata()\n→ Ingest" fillcolor="#a9dfbf" fontcolor="#1e8449"]
    cfg_edge_io  [label="load_cfg_edges()\n→ Ingest"         fillcolor="#a9dfbf" fontcolor="#1e8449"]

    /* ── CLI flag / path data nodes ─────────────────────────────── */
    ll_path    [label=".ll path"                    fillcolor="#f4b8d4" fontcolor="#7a1545" shape=note]
    dot_path   [label=".dot path"                   fillcolor="#f4b8d4" fontcolor="#7a1545" shape=note]
    trace_flag [label="--import-trace"              fillcolor="#f4b8d4" fontcolor="#7a1545" shape=note]
    meta_flag  [label="--import-analysis-\nmetadata" fillcolor="#f4b8d4" fontcolor="#7a1545" shape=note]
    edges_flag [label="--import-cfg-edges"          fillcolor="#f4b8d4" fontcolor="#7a1545" shape=note]

    /* ── File inputs → CLI ──────────────────────────────────────── */
    input_ll  -> cli_main [weight=10]
    input_dot -> cli_main

    /* ── CLI dispatch → Ingest stubs ────────────────────────────── */
    cli_main -> ll_path    [weight=10]
    cli_main -> dot_path
    cli_main -> trace_flag
    cli_main -> meta_flag
    cli_main -> edges_flag

    ll_path    -> parse_events [weight=10]
    dot_path   -> dot_layout
    trace_flag -> trace_io
    meta_flag  -> meta_io
    edges_flag -> cfg_edge_io
}
