// Extracted subgraph: ir_mode branch from 02_stack_animation_flow
digraph ir_mode_branch {
    graph [
        fontname = "Helvetica" fontsize = 13
        label    = "ir_mode Branch (basic | rich | rich-ssa)"
        labelloc = "t" rankdir = LR splines = ortho
        nodesep = 0.7 ranksep = 1.2 pad = 0.4 bgcolor = "white"
    ]
    node [fontname="Helvetica" fontsize=11 style="filled,rounded" shape=box]
    edge [fontname="Helvetica" fontsize=10 color="#555555" arrowsize=0.85]

    // ── Internal ───────────────────────────────────────────────────
    subgraph cluster_mode {

        label = "ir_mode branch"
        style = filled fillcolor = "#f5f6fa" color = "#636e72"
        penwidth = 1.5 fontname = "Helvetica" fontsize = 11

        mode_basic [label="basic\n(raw opcodes)"
                    fillcolor="#ecf0f1" fontcolor="#2c3e50"]
        mode_rich  [label="rich\n(formatted operands)"
                    fillcolor="#ecf0f1" fontcolor="#2c3e50"]
        mode_ssa   [label="rich-ssa\n(SSA register colours)"
                    fillcolor="#ecf0f1" fontcolor="#2c3e50"]
        {rank=same; mode_basic; mode_rich; mode_ssa}

        display_lines [label="build_display_lines()\ningest/display_lines.py"
                       fillcolor="#27ae60" fontcolor="white"]

        mode_rich -> display_lines [minlen=2 xlabel=" annotates"]
        mode_ssa  -> display_lines [minlen=2 xlabel=" annotates"]
    }

    // ── External stubs ─────────────────────────────────────────────
    pest        [label="ProgramEventStream\n← parse" fillcolor="#a9dfbf" fontcolor="#1e8449"]
    build_stack [label="build_scene_graph(stack)\n→ Transform" fillcolor="#f5cba7" fontcolor="#ca6f1e"]

    // ── Edges ──────────────────────────────────────────────────────
    pest -> mode_basic
    pest -> mode_rich
    pest -> mode_ssa

    mode_basic    -> build_stack [minlen=2 xlabel=" PES"]
    mode_rich     -> build_stack [minlen=2 xlabel=" PES"]
    mode_ssa      -> build_stack [minlen=2 xlabel=" PES"]
    display_lines -> build_stack [style=dashed minlen=2 xlabel=" display_lines\n(rich modes only)"]
}
