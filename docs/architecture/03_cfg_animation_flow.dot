// LLVManim: CFG Animation Pipeline
// Shows the two input paths (.ll and .dot), the dual trace routes,
// and how they merge at CFGRenderer.
digraph cfg_flow {
    graph [
        fontname = "Helvetica"
        fontsize = 13
        label    = "LLVManim: CFG Animation Pipeline"
        labelloc = "t"
        splines  = true
        nodesep  = 0.6
        ranksep  = 0.9
        bgcolor  = "white"
    ]
    node [fontname="Helvetica" fontsize=11 style="filled,rounded" shape=box]
    edge [fontname="Helvetica" fontsize=10]

    // ── Inputs ─────────────────────────────────────────────────────
    input_ll  [label="input.ll\n(LLVM-IR)"
               fillcolor="#e74c3c" fontcolor="white" shape=note]
    input_dot [label="layout.dot\n(pre-computed Graphviz,\noptional)"
               fillcolor="#e74c3c" fontcolor="white" shape=note]
    input_trace [label="trace.json\n(--import-trace, optional)"
                 fillcolor="#e74c3c" fontcolor="white" shape=note]

    // ── Ingest: IR path ────────────────────────────────────────────
    parse_events [label="parse_module_to_events()\ningest/llvm_events.py"
                  fillcolor="#2980b9" fontcolor="white"]
    meta_io      [label="load_analysis_metadata()\ningest/analysis_metadata_io.py\n(optional, --analysis-metadata)"
                  fillcolor="#2980b9" fontcolor="white"]

    // ── Ingest: layout path ────────────────────────────────────────
    dot_layout [label="compute_dot_layout()\ningest/dot_layout.py"
                fillcolor="#2980b9" fontcolor="white"]

    // ── Transform: scene graph ─────────────────────────────────────
    build_scene [label="build_scene_graph()\ntransform/scene_graph.py"
                 fillcolor="#2980b9" fontcolor="white"]

    scene_graph [label="SceneGraph\n(nodes, edges, TraceOverlay)"
                 fillcolor="#8e44ad" fontcolor="white"]

    // ── Trace routes ───────────────────────────────────────────────
    subgraph cluster_trace {
        label     = "Trace source (mutually exclusive)"
        style     = filled
        fillcolor = "#f5f6fa"
        color     = "#636e72"
        fontname  = "Helvetica"
        fontsize  = 11

        load_trace   [label="load_trace()\ningest/trace_io.py\n(--import-trace)"
                      fillcolor="#2980b9" fontcolor="white"]
        derive_trace [label="derive_cfg_trace()\ntransform/trace.py\n(auto-derived)"
                      fillcolor="#2980b9" fontcolor="white"]
    }

    overlay [label="TraceOverlay\n(entry_order, visited_nodes,\ntraversed_edges, reason)"
             fillcolor="#8e44ad" fontcolor="white"]

    // ── Render ─────────────────────────────────────────────────────
    cfg_renderer [label="CFGRenderer\nrender/cfg_renderer.py"
                  fillcolor="#8e44ad" fontcolor="white"]

    manim [label="Manim Community Edition"
           fillcolor="#636e72" fontcolor="white" style="filled"]

    // ── Outputs ────────────────────────────────────────────────────
    out_dot [label="cfg_*.dot\ncfg_*.png\n(--draw)"
             fillcolor="#27ae60" fontcolor="white" shape=note]
    out_mp4 [label="cfg animation\n(MP4 / GIF)"
             fillcolor="#27ae60" fontcolor="white" shape=note]

    // ── Edges ──────────────────────────────────────────────────────
    input_ll    -> parse_events  [label=" .ll path"]
    input_dot   -> dot_layout    [label=" .dot path"]
    input_trace -> load_trace    [label=" --import-trace"]
    meta_io     -> build_scene   [label=" BlockMetadata\n(optional)" style=dashed]

    parse_events -> build_scene  [label=" ProgramEventStream"]
    dot_layout   -> out_dot      [label=" --draw"]
    dot_layout   -> cfg_renderer [label=" DotLayout\n(node positions)"]

    build_scene  -> derive_trace [label=" SceneGraph (no trace)"]
    load_trace   -> overlay      [label=" loaded"]
    derive_trace -> overlay      [label=" computed"]

    overlay     -> build_scene   [label=" injected back" style=dashed]
    build_scene -> scene_graph

    scene_graph  -> cfg_renderer
    cfg_renderer -> manim
    manim        -> out_mp4
}
