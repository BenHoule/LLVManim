// Extracted subgraph: CFG ingest path from 03_cfg_animation_flow
// Covers the data-loading stage: LLVM-IR parsing, optional metadata/edge
// imports, and Graphviz layout computation.
digraph cfg_ingest {
    graph [
        fontname = "Helvetica" fontsize = 13
        label    = "CFG Ingest Path"
        labelloc = "t" splines = ortho nodesep = 0.8 ranksep = 1.15
        pad = 0.4 bgcolor = "white"
    ]
    node [fontname="Helvetica" fontsize=11 style="filled,rounded" shape=box]
    edge [fontname="Helvetica" fontsize=10 color="#555555" arrowsize=0.85]

    // ── Inputs ─────────────────────────────────────────────────────
    input_ll  [label="input.ll\n(LLVM-IR)"
               fillcolor="#f1c40f" fontcolor="#2c3e50" shape=note]
    input_dot [label="layout.dot\n(pre-computed Graphviz,\noptional)"
               fillcolor="#f1c40f" fontcolor="#2c3e50" shape=note]
    {rank=same; input_ll; input_dot}

    // ── Internal ───────────────────────────────────────────────────
    subgraph cluster_ingest {

        label     = "Ingest  (llvmanim/ingest/)"
        style     = filled
        fillcolor = "#d5f5e3"
        color     = "#1e8449"
        penwidth  = 1.5
        fontname  = "Helvetica"
        fontsize  = 12
        fontcolor = "#1e8449"

        parse_events [label="parse_module_to_events()\ningest/llvm_events.py"
                      fillcolor="#27ae60" fontcolor="white"]
        meta_io      [label="load_analysis_metadata()\ningest/analysis_metadata_io.py\n(optional, --import-analysis-metadata)"
                      fillcolor="#27ae60" fontcolor="white"]
        cfg_edge_io  [label="load_cfg_edges()\ningest/cfg_edge_io.py\n(optional, --import-cfg-edges)"
                      fillcolor="#27ae60" fontcolor="white"]
        dot_layout   [label="compute_dot_layout()\ningest/dot_layout.py"
                      fillcolor="#27ae60" fontcolor="white"]
    }

    // ── Third-party libraries ──────────────────────────────────────
    llvmlite [label="llvmlite\n(3rd party)" fillcolor="#bdc3c7" fontcolor="#2c3e50"]
    graphviz [label="graphviz\n(3rd party)" fillcolor="#bdc3c7" fontcolor="#2c3e50"]

    // ── External stubs (outgoing) ──────────────────────────────────
    build_scene  [label="build_scene_graph(cfg)\n→ Transform" fillcolor="#f5cba7" fontcolor="#ca6f1e"]
    cfg_renderer [label="CFGRenderer\n→ Render"               fillcolor="#a9cce3" fontcolor="#1a5276"]
    out_dot      [label="cfg_*.dot / cfg_*.png\n(--draw)"
                  fillcolor="#f9c4bf" fontcolor="#8e2019" shape=note]

    // ── Edges ──────────────────────────────────────────────────────
    input_ll  -> parse_events [minlen=2 xlabel=" .ll path"]
    input_dot -> dot_layout   [minlen=2 xlabel=" .dot path"]

    parse_events -> build_scene [minlen=2 xlabel=" ProgramEventStream"]
    meta_io      -> build_scene [style=dashed minlen=2 xlabel=" BlockMetadata\n(optional)"]
    cfg_edge_io  -> build_scene [style=dashed minlen=2 xlabel=" cfg_edges\n(override)"]
    dot_layout   -> cfg_renderer [minlen=2 xlabel=" DotLayout\n(node positions)"]
    dot_layout   -> out_dot      [minlen=2 xlabel=" --draw"]

    // 3rd-party import edges
    parse_events -> llvmlite [style=dashed minlen=2 xlabel="  import" color="#999999"]
    dot_layout   -> graphviz [style=dashed minlen=2 xlabel="  import" color="#999999"]
}
