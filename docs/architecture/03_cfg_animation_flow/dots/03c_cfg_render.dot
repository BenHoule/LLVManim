// Extracted subgraph: CFG render path from 03_cfg_animation_flow
// Covers the animation-generation stage: overlay command building,
// the CFGRenderer + cfg_animation_scene helpers, Manim, and output.
digraph cfg_render {
    graph [
        fontname = "Helvetica" fontsize = 13
        label    = "CFG Render Pipeline"
        labelloc = "t" splines = ortho nodesep = 0.8 ranksep = 1.25
        pad = 0.4 bgcolor = "white"
    ]
    node [fontname="Helvetica" fontsize=11 style="filled,rounded" shape=box]
    edge [fontname="Helvetica" fontsize=10 color="#555555" arrowsize=0.85]

    // ── External stubs (incoming) ──────────────────────────────────
    scene_graph [label="SceneGraph\n← build_scene_graph"     fillcolor="#d7bde2" fontcolor="#6c3483"]
    dot_layout  [label="compute_dot_layout()\n← Ingest"      fillcolor="#a9dfbf" fontcolor="#1e8449"]

    // ── Transform ──────────────────────────────────────────────────
    subgraph cluster_transform {

        label     = "Transform  (llvmanim/transform/)"
        style     = filled
        fillcolor = "#fdebd0"
        color     = "#ca6f1e"
        penwidth  = 1.5
        fontname  = "Helvetica"
        fontsize  = 12
        fontcolor = "#ca6f1e"

        build_overlay_cmds [label="_build_overlay_commands()\ntransform/scene.py"
                             fillcolor="#e67e22" fontcolor="white"]
    }

    // ── Render ─────────────────────────────────────────────────────
    subgraph cluster_render {

        label     = "Render  (llvmanim/render/)"
        style     = filled
        fillcolor = "#d4e6f1"
        color     = "#1a5276"
        penwidth  = 1.5
        fontname  = "Helvetica"
        fontsize  = 12
        fontcolor = "#1a5276"

        cfg_anim_scene [label="cfg_animation_scene.py\n(_CoordMapper, build helpers)"
                        fillcolor="#2980b9" fontcolor="white"]
        cfg_renderer   [label="CFGRenderer\nrender/cfg_renderer.py"
                        fillcolor="#2980b9" fontcolor="white"]
        manim          [label="Manim Community Edition\n(3rd party)"
                        fillcolor="#bdc3c7" fontcolor="#2c3e50"]
    }

    // ── Output ─────────────────────────────────────────────────────
    out_mp4 [label="cfg animation\n(MP4 / GIF)"
             fillcolor="#e74c3c" fontcolor="white" shape=note]

    // ── Edges ──────────────────────────────────────────────────────
    scene_graph        -> build_overlay_cmds [minlen=2 xlabel=" --cfg-animate"]
    build_overlay_cmds -> cfg_renderer       [minlen=2 xlabel=" SceneGraph\n(+commands)"]

    dot_layout -> cfg_renderer [minlen=2 xlabel=" DotLayout\n(node positions)"]

    // UML dependency: cfg_renderer imports cfg_animation_scene
    cfg_renderer   -> cfg_anim_scene [style=dashed minlen=2 xlabel=" import" color="#999999"]
    // UML dependency: cfg_animation_scene imports dot_layout types
    cfg_anim_scene -> dot_layout     [style=dashed minlen=2 xlabel=" import" color="#999999"]

    cfg_renderer -> manim
    manim        -> out_mp4
}
